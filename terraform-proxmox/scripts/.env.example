# Copy to scripts/.env on the Proxmox host and set mode 600.
#
# This file is consumed by scripts/create-cloudinit-vm_stable.sh.
# It configures cloud-init VM defaults and Zabbix Agent 2 bootstrap targets.

CIUSER="ansible"
PASSWORD="<set-strong-cloud-init-password>"
SSH_KEYS_FILE="/root/.ssh/authorized_keys"

# Backward-compatible single target (applies to both Server and ServerActive).
ZABBIX_SERVER="198.51.100.23"

# Optional split targets (override ZABBIX_SERVER behavior when set):
# ZABBIX_SERVER_PASSIVE="198.51.100.23"
# ZABBIX_SERVER_ACTIVE="198.51.100.23:10051"
