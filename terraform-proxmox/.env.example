# Copy this file to .env and fill in real values.
# .env contains secrets and should not be committed.
# Recommended permissions: chmod 600 .env

# Use a Vault endpoint reachable from this machine:
# - LAN client: https://198.51.100.12:8200 (or your Vault DNS name)
# - Local only: https://127.0.0.1:8200

# Terraform variables
TF_VAR_vault_address=https://198.51.100.12:8200
# IMPORTANT: replace placeholders before sourcing .env.
# Keep placeholder lines commented until you set real values.
# TF_VAR_vault_token=<vault-token>

# Vault CLI variables
VAULT_ADDR=https://198.51.100.12:8200

# Vault auth (choose one):
# 1) Static token (legacy/simple)
# VAULT_TOKEN=<vault-token>
#
# 2) AppRole (recommended for rotation; token is fetched/cached automatically)
# VAULT_ROLE_ID=<approle-role-id>
# VAULT_SECRET_ID=<approle-secret-id>
# Optional token cache file used by scripts/vault-auth.sh
# VAULT_TOKEN_FILE=.vault-token

# Self-signed TLS (choose one). VAULT_CACERT should be a local path on this machine.
# VAULT_CACERT=/path/to/vault-cert.pem
# VAULT_SKIP_VERIFY=true

# Optional Cloudflare R2 remote state credentials for Terraform.
# When using the S3-compatible backend in terraform-proxmox/backend.tf, provide
# your R2 access credentials here or via the environment.
# AWS_ACCESS_KEY_ID=<r2-access-key-id>
# AWS_SECRET_ACCESS_KEY=<r2-secret-access-key>
# AWS_REGION=us-east-1
# AWS_SESSION_TOKEN=<optional-session-token>

# Packer Vault credential hydration (recommended)
PACKER_USE_VAULT_CREDS=true
# Optional override. If unset, Makefile uses: secret/terraform/<ENVIRONMENT>/creds
# PACKER_VAULT_PATH=secret/terraform/dev/creds

# Proxmox defaults used by rotate-proxmox-creds/upload-snippets (optional)
PROXMOX_USER=root
SSH_STRICT_HOST_KEY_CHECKING=accept-new
PROXMOX_HOST_PROD=198.51.100.13
PROXMOX_HOST_DEV=198.51.100.14
PROXMOX_HOST_TESTING=198.51.100.15
# PROXMOX_HOST=192.0.2.x
# Add additional environments with upper-case suffixes:
# PROXMOX_HOST_QA=198.51.100.11
# PROXMOX_NODE_QA=proxmox
# ANSIBLE_HOST_QA=198.51.100.16   # optional; auto-detected from local route when omitted
# NETWORK_CIDR_QA=192.0.2.0/24
# NETWORK_GW_QA=198.51.100.17
# STORAGE_POOL_QA=local-lvm
# DATA_STORAGE_QA=local-lvm

# Auto-discovery for env-template/env-bootstrap (recommended)
AUTO_DISCOVER=true

# Vault destructive recovery/reinit defaults (optional)
# VAULT_RECOVERY_DIR=/home/<user>/.vault-recovery
# VAULT_INIT_SHARES=3
# VAULT_INIT_THRESHOLD=2
# VAULT_RECOVERY_PASSPHRASE=<strong-passphrase>
# VAULT_KV_MOUNT_PATH=secret

# Vault TLS regeneration defaults (optional; used by vault-tls-regenerate/vault-mode-lan-auto)
# If omitted, LAN IP auto-detects from this host route to Proxmox.
# VAULT_LAN_IP=198.51.100.12
# VAULT_LAN_HOST=198.51.100.12
# VAULT_TLS_DAYS=365

# Vault mode switch behavior (optional)
# VAULT_AUTO_UNSEAL=true
