# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ansible vault password (centralized)
.ansible/
.vault_password
.env
.env.*
!.env.example
test-runs/
AGENTS.md
GEMINI.md
CLAUDE.md
ansible/bootstrap_playbooks/jenkins/files/*
ansible/bootstrap_playbooks/gitlab/files/*
ansible/bootstrap_playbooks/freeipa/files/*
ansible/bootstrap_playbooks/keycloak/files/*
ansible/bootstrap_playbooks/observability/files/*
ansible/bootstrap_playbooks/zabbix_server/files/*
ansible/bootstrap_playbooks/zimbra/files/*

# Virtual environments (vendored packages trigger false-positive secret scans)
tmp_venv/
.venv/
venv/

# Generated structure dumps
structure.txt
