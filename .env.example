# Global security-sensitive overrides for repo-level scripts.
# Copy to .env and set strong values before running test/rebuild helpers.

DB_SYS_PASSWORD=<set-strong-db-sys-password>
APP_USER=APP_CRM
APP_USER_PASSWORD=<set-strong-app-user-password>

# SSH host-key policy for helper scripts/tests.
# Recommended: accept-new (trust on first use, reject key changes).
SSH_STRICT_HOST_KEY_CHECKING=accept-new
