#!/bin/bash
if [ -f {{ oracle_scripts_dir }}/setEnv.sh ]; then
  . {{ oracle_scripts_dir }}/setEnv.sh
fi

export ORAENV_ASK=NO
if command -v oraenv >/dev/null 2>&1; then
  . oraenv
elif [ -f /usr/local/bin/oraenv ]; then
  . /usr/local/bin/oraenv
fi
export ORAENV_ASK=YES

if [ -n "$ORACLE_HOME" ] && [ -x "$ORACLE_HOME/bin/dbstart" ]; then
  "$ORACLE_HOME/bin/dbstart" "$ORACLE_HOME"
else
  # Fallback manual startup if dbstart is not available
  if command -v lsnrctl >/dev/null 2>&1; then
    lsnrctl start || true
  fi
  ps -eo args= | awk '/ora_pmon_/ {print $1}' | awk -F_ '{print $3}' | while read -r sid; do
    export ORACLE_SID="$sid"
    if command -v sqlplus >/dev/null 2>&1; then
      printf "startup;\nexit;\n" | sqlplus -s / as sysdba || true
    fi
  done
fi
