# Oracle Settings
export TMP=/tmp
export TMPDIR=$TMP

export ORACLE_HOSTNAME={{ oracle_hostname }}
export ORACLE_UNQNAME={{ oracle_databases[0].global_db_name }}
export ORACLE_BASE={{ oracle_base }}
export ORACLE_HOME=$ORACLE_BASE/product/19.0.0/dbhome_1
export ORA_INVENTORY={{ oracle_inventory_loc }}
export ORACLE_SID={{ oracle_databases[0].sid }}
export PDB_NAME={{ oracle_databases[0].pdb_name }}
export DATA_DIR={{ oracle_data_dir }}

export PATH=/usr/sbin:/usr/local/bin:$PATH
export PATH=$ORACLE_HOME/bin:$PATH

export LD_LIBRARY_PATH=$ORACLE_HOME/lib:/lib:/usr/lib
export CLASSPATH=$ORACLE_HOME/jlib:$ORACLE_HOME/rdbms/jlib
