#!/bin/bash
# ============================================================================
# Database Cleanup Script
# Deployed by Ansible — DO NOT EDIT MANUALLY
#
# Runs daily via cron.  Safe to execute while the database is running.
#   - Keeps the last N audit files (.aud) per adump directory
#   - Purges trace files older than N minutes via ADRCI
#   - Purges core dumps older than N minutes via ADRCI
# ============================================================================
set -euo pipefail

export ORACLE_HOME={{ oracle_home }}
export PATH="${ORACLE_HOME}/bin:${ORACLE_HOME}/OPatch:/usr/local/bin:/usr/bin:/bin"

# ---------------------------------------------------------------------------
# Configuration (populated by Ansible)
# ---------------------------------------------------------------------------
KEEP={{ cleanup_keep_count }}
SKIP=$((KEEP + 1))

LOG_FILE={{ cleanup_log_dir }}/cleanup_database.log

# ---------------------------------------------------------------------------
# Logging helper
# ---------------------------------------------------------------------------
log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] CLEANUP: $*" >> "$LOG_FILE"
}

# Ensure the log directory exists before we write anything
mkdir -p "$(dirname "$LOG_FILE")"

log "========== Database cleanup started =========="

# ===========================================================================
# D1: Audit files (.aud)
#
# For each configured adump directory, keep the most recent $KEEP files
# and remove the rest (sorted by modification time, newest first).
# ===========================================================================
{% for adump_dir in cleanup_db_adump_dirs %}
if [ -d "{{ adump_dir }}" ]; then
  log "Pruning audit files in {{ adump_dir }}"
  TOTAL=$(find "{{ adump_dir }}" -maxdepth 1 -name '*.aud' -printf '.' 2>/dev/null | wc -c)
  TO_DELETE=$((TOTAL > KEEP ? TOTAL - KEEP : 0))
  if [ "$TO_DELETE" -gt 0 ]; then
    find "{{ adump_dir }}" -maxdepth 1 -name '*.aud' -printf '%T@\t%p\n' 2>/dev/null | sort -nr | tail -n +${SKIP} | cut -f2 | xargs -r rm -f
    log "  Removed ${TO_DELETE} audit file(s) (kept ${KEEP})"
  else
    log "  Nothing to prune (${TOTAL} files, keeping ${KEEP})"
  fi
fi
{% endfor %}

# ===========================================================================
# D2/D3: Trace files via ADRCI
#
# Purge trace files older than the configured age (in minutes) from each
# ADR home.  Default: 10080 minutes = 7 days.
# ===========================================================================
{% for adr_home in cleanup_db_adr_homes %}
log "Purging trace files via ADRCI for {{ adr_home }}"
if command -v adrci &>/dev/null; then
  adrci exec="set homepath {{ adr_home }}; purge -age {{ cleanup_adrci_trace_minutes | default(10080) }} -type TRACE" 2>/dev/null && \
    log "  ADRCI trace purge completed for {{ adr_home }}" || \
    log "  ADRCI trace purge failed for {{ adr_home }} (non-fatal)"
else
  log "  ADRCI not found — skipping trace purge for {{ adr_home }}"
fi
{% endfor %}

# ===========================================================================
# D6: Core dumps via ADRCI
#
# Purge core dump files older than the configured age (in minutes) from each
# ADR home.  Default: 10080 minutes = 7 days.
# ===========================================================================
{% for adr_home in cleanup_db_adr_homes %}
log "Purging core dumps via ADRCI for {{ adr_home }}"
if command -v adrci &>/dev/null; then
  adrci exec="set homepath {{ adr_home }}; purge -age {{ cleanup_adrci_cdump_minutes | default(10080) }} -type CDUMP" 2>/dev/null && \
    log "  ADRCI cdump purge completed for {{ adr_home }}" || \
    log "  ADRCI cdump purge failed for {{ adr_home }} (non-fatal)"
else
  log "  ADRCI not found — skipping cdump purge for {{ adr_home }}"
fi
{% endfor %}

log "Database cleanup complete."
