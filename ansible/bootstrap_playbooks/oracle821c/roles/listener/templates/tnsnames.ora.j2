# tnsnames.ora generated by Ansible
{% for pdb in oracle_pdbs | default([]) %}
{% if pdb.pdb_name is defined and (pdb.pdb_name | string | length) > 0 and not ((pdb.pdb_name | string) is search('__omit_place_holder__')) %}
{{ pdb.pdb_name }} =
  (DESCRIPTION =
    (ADDRESS = (PROTOCOL = TCP)(HOST = {{ oracle_hostname }})(PORT = {{ pdb.listener_port | default(oracle_listener_port) }}))
    (CONNECT_DATA =
      (SERVER = DEDICATED)
      (SERVICE_NAME = {{ pdb.service_name | default(pdb.pdb_name) }})
    )
  )

{% endif %}
{% endfor %}
