# Copy to ansible/bootstrap_playbooks/jenkins/.env and chmod 600.

# Jenkins Controller configuration
JENKINS_VERSION=2.555.3
# Optional: install from a pre-downloaded .deb instead of the Jenkins apt repo.
# JENKINS_PACKAGE_PATH=/resources/jenkins_2.555.3_all.deb
JENKINS_HTTP_PORT=8080
# The IP or domain where Jenkins will listen
JENKINS_LISTEN_ADDRESS=0.0.0.0
JENKINS_URL=http://198.51.100.29:8080
JENKINS_SYSTEM_MESSAGE="Homelab Jenkins managed by Ansible"
JENKINS_CONTROLLER_EXECUTORS=0

# Admin details
JENKINS_ADMIN_USER=admin
# Leave unset to generate ansible/bootstrap_playbooks/jenkins/files/jenkins_admin_password.
JENKINS_ADMIN_PASSWORD=

# Jenkins 2.555.x requires Java 21 or Java 25 on the controller and agents.
JENKINS_JAVA_INSTALL_METHOD=apt
JENKINS_JAVA_PACKAGE=openjdk-21-jdk
JENKINS_JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
# Optional local archive mode after pre-downloading a Java 21 tarball.
# JENKINS_JAVA_INSTALL_METHOD=local
# JDK_ARCHIVE_PATH=/resources/jdk-21_linux-x64_bin.tar.gz
# JDK_DEST_DIR=/opt
# JDK_VERSION_DIR=jdk-21.0.11+10
# JAVA_HOME=/opt/jdk-21.0.11+10

# Java options (e.g. heap size limits)
JENKINS_JAVA_OPTS="-Xms512m -Xmx2048m -Djenkins.install.runSetupWizard=false"

# Core plugins to install on startup (comma-separated)
JENKINS_PLUGINS=configuration-as-code,git,workflow-aggregator,credentials,credentials-binding,ssh-slaves,ssh-agent,gitlab-plugin,cloudbees-folder,job-dsl,matrix-auth,pipeline-stage-view,timestamper,ws-cleanup,build-timeout,junit,email-ext,dark-theme,theme-manager

# UI defaults
JENKINS_THEME=darkSystem
JENKINS_DISABLE_USER_THEMES=true

# Jenkins Agent configuration (SSH-based)
# Leave JENKINS_MANAGE_AGENTS=true and omit JENKINS_AGENT_* values to
# auto-discover all hosts in the jenkins_agent/jenkins_agents inventory groups.
# Set JENKINS_MANAGE_AGENTS=false for a standalone controller with no build nodes.
JENKINS_MANAGE_AGENTS=true
JENKINS_AUTODISCOVER_AGENTS=true
# Set true only when JENKINS_AGENT_* points to an externally managed node
# that is not present in the Ansible inventory.
JENKINS_ALLOW_EXTERNAL_AGENTS=false
# Optional single-agent override. For multiple agents, prefer inventory
# hosts/group_vars or set jenkins_agents as a YAML list.
# JENKINS_AGENT_NAME=public-pve1-jenkins-agent-01
# JENKINS_AGENT_HOST=198.51.100.30
# JENKINS_AGENT_USER=jenkins
# JENKINS_AGENT_WORK_DIR=/home/jenkins
# JENKINS_AGENT_EXECUTORS=4
# JENKINS_AGENT_LABELS=linux,docker,homelab
# JENKINS_AGENT_MODE=EXCLUSIVE
# JENKINS_AGENT_PORT=22
# JENKINS_AGENT_JVM_OPTIONS=-Xmx512m
JENKINS_AGENT_INSTALL_DOCKER=true
