# Optional overrides. Without this file, the playbook uses tracked non-secret
# group variables and generates distinct local passwords under files/ with mode
# 0600. Inject vaulted variables instead when centralized secret custody exists.

# Optional strong secret overrides (20 characters minimum and must differ).
FREEIPA_DS_PASSWORD=<set-strong-ds-password>
FREEIPA_ADMIN_PASSWORD=<set-strong-admin-password>

# Identity defaults.
FREEIPA_DOMAIN=example.internal
FREEIPA_REALM=EXAMPLE.INTERNAL
# Optional explicit server identity (otherwise computed from inventory + domain).
# FREEIPA_SERVER_FQDN=freeipa.example.internal
# FREEIPA_SERVER_IP=198.51.100.25
# true  = install and manage integrated DNS on the FreeIPA host.
# false = external DNS mode; publish FreeIPA A/SRV/URI/ipa-ca records in
#         Pi-hole or another authoritative DNS service before reruns.
FREEIPA_SETUP_DNS=true
FREEIPA_SETUP_KRA=false
FREEIPA_NO_NTP=true
FREEIPA_NO_HOST_DNS=true

# Optional DNS forwarders (comma-separated).
FREEIPA_FORWARDERS=198.51.100.23,198.51.100.27

# Optional platform controls.
FREEIPA_MANAGE_FIREWALL=true
FREEIPA_CONFIGURE_HOSTS=true
