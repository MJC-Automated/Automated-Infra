# templates/create_domain.py.j2
# WLST (WebLogic Scripting Tool) script to create a WebLogic 14c domain.

import os

mw_home = '{{ oracle_middleware_home }}'
domain_name = '{{ wlst_domain_name | default(domain_name) }}'
domain_home = '{{ wlst_domain_home | default(domain_home) }}'
admin_user = '{{ wlst_admin_user | default(weblogic_admin_user) }}'
admin_password = '{{ weblogic_password }}'
admin_server_name = '{{ wlst_admin_server_name | default(admin_server_name) }}'
admin_port = {{ wlst_admin_port | default(admin_port) }}
admin_address = '{{ admin_listen_address }}'
java_home = '{{ java_home }}'
app_dir = '{{ wlst_app_dir | default(applications_base) }}'
coherence_port = {{ wlst_coherence_port | default(7574) }}
coherence_clustering_mode = '{{ wlst_coherence_clustering_mode | default(coherence_clustering_mode | default("unicast")) }}'

cluster_enabled = {{ 'True' if cluster_enabled else 'False' }}
cluster_name = '{{ cluster_name }}'

tunneling_enabled = {{ 'True' if weblogic_tunneling_enabled else 'False' }}

managed_servers = {{ wlst_managed_servers | default(((managed_server_enable | bool) | ternary(managed_servers, []))) | to_json }}
machines = {{ machines | to_json }}
compact_domain_profile_enabled = {{ 'True' if compact_domain_profile_enabled else 'False' }}
compact_domain_enable_soapjms = {{ 'True' if compact_domain_enable_soapjms else 'False' }}
compact_domain_jrf_templates = {{ (compact_domain_jrf_templates | default([compact_domain_jrf_template])) | to_json }}
compact_domain_soapjms_templates = {{ (compact_domain_soapjms_templates | default([compact_domain_soapjms_template])) | to_json }}
compact_domain_em_templates = {{ (compact_domain_em_templates | default([])) | to_json }}
compact_domain_set_default_jdbc_passwords = {{ 'True' if compact_domain_set_default_jdbc_passwords else 'False' }}
compact_domain_jdbc_password_datasources = {{ (compact_domain_jdbc_password_datasources | default([])) | to_json }}

def add_first_available_template(template_paths, template_label):
    for template_path in template_paths:
        if os.path.exists(template_path):
            print 'INFO: Adding domain template (' + template_label + '): ' + template_path
            addTemplate(template_path)
            return template_path
        else:
            print 'INFO: Domain template candidate not found for ' + template_label + ': ' + template_path
    raise Exception('Required domain template for ' + template_label + ' not found. Checked: ' + ', '.join(template_paths))

def set_datasource_password_if_present(datasource_name, datasource_password):
    ds_path = '/JDBCSystemResource/' + datasource_name + '/JdbcResource/' + datasource_name + '/JDBCDriverParams/NO_NAME_0'
    try:
        cd(ds_path)
        set('PasswordEncrypted', datasource_password)
        print 'INFO: Set JDBC password for datasource: ' + datasource_name
        cd('/')
        return True
    except:
        print 'INFO: Datasource not present, skipping JDBC password set: ' + datasource_name
        cd('/')
        return False

def configure_coherence_cluster():
    try:
        cd('CoherenceClusterSystemResource/defaultCoherenceCluster/CoherenceResource/defaultCoherenceCluster/CoherenceClusterParams/NO_NAME_0')
        set('ClusteringMode', coherence_clustering_mode)
        set('ClusterListenPort', int(coherence_port))
        print 'INFO: Configured coherence cluster port to ' + str(coherence_port)
        cd('/')
    except Exception, e:
        print 'WARNING: Failed to configure coherence cluster: ' + str(e)
        cd('/')

print 'INFO: Middleware Home: ' + mw_home
print 'INFO: Domain Home: ' + domain_home
print 'INFO: Domain Name: ' + domain_name
print 'INFO: Admin Server: ' + admin_server_name
print 'INFO: Admin Port: ' + str(admin_port)

domain_config = domain_home + '/config/config.xml'
if os.path.exists(domain_config):
    print 'WARNING: Domain already exists at ' + domain_home
    print 'WARNING: Skipping domain creation.'
    exit()

# Create a new domain from the WebLogic template
readTemplate(mw_home + '/wlserver/common/templates/wls/wls.jar')

class MockAdminConsole(object):
    def setCookieName(self, name):
        print 'INFO: Mock setCookieName to ' + name

class WlsCmoWrapper(object):
    def __init__(self, real_cmo):
        self.__dict__['_real_cmo'] = real_cmo
    def getAdminConsole(self):
        try:
            ac = self._real_cmo.getAdminConsole()
            if ac is not None:
                return ac
        except:
            pass
        return MockAdminConsole()
    def __getattr__(self, name):
        return getattr(self._real_cmo, name)
    def __setattr__(self, name, value):
        setattr(self._real_cmo, name, value)

original_cd = cd
def cd(path):
    original_cd(path)
    global cmo
    cmo = WlsCmoWrapper(cmo)

cmo = WlsCmoWrapper(cmo)

# Try to create the AdminConsole configuration bean offline if not present
try:
    if isinstance(cmo.getAdminConsole(), MockAdminConsole):
        original_cd('/')
        create('console', 'AdminConsole')
except:
    pass

if compact_domain_profile_enabled:
    print 'INFO: Enabling compact-domain template profile for ADF apps.'
    selected_jrf_template = add_first_available_template(compact_domain_jrf_templates, 'Oracle JRF [oracle_common]')
    if compact_domain_enable_soapjms:
        if selected_jrf_template.find('restricted') != -1:
            raise Exception('Oracle JRF SOAPS/JMS Web Services requires full JRF (DB-backed profile). Disable compact_domain_enable_soapjms for no-DB compact domains.')
        add_first_available_template(compact_domain_soapjms_templates, 'Oracle JRF SOAPS/JMS Web Services [oracle_common]')
    else:
        print 'INFO: compact_domain_enable_soapjms=false; skipping Oracle JRF SOAPS/JMS Web Services template.'
    add_first_available_template(compact_domain_em_templates, 'Oracle Enterprise Manager [em]')
    if compact_domain_set_default_jdbc_passwords:
        for ds_name in compact_domain_jdbc_password_datasources:
            set_datasource_password_if_present(ds_name, admin_password)

    configure_coherence_cluster()

setOption('DomainName', domain_name)
setOption('OverwriteDomain', 'true')
setOption('JavaHome', java_home)
setOption('AppDir', app_dir)

# Configure the Admin Server
cd('/Servers/AdminServer')
set('Name', admin_server_name)
if admin_address:
    set('ListenAddress', admin_address)
set('ListenPort', admin_port)
# Enable HTTP tunneling on AdminServer
if tunneling_enabled:
    set('TunnelingEnabled', 'true')
else:
    set('TunnelingEnabled', 'false')

# Set WebLogic Administrator password
cd('/Security/base_domain/User/' + admin_user)
cmo.setPassword(admin_password)

# Create cluster (optional)
if cluster_enabled and cluster_name:
    cd('/')
    create(cluster_name, 'Cluster')

# Create machines and Node Manager settings
for machine in machines:
    mname = machine.get('name')
    if not mname:
        continue
    cd('/')
    create(mname, 'Machine')
    cd('/Machines/' + mname)
    create('NodeManager', 'NodeManager')
    cd('NodeManager')
    if machine.get('nm_listen_address'):
        set('ListenAddress', machine.get('nm_listen_address'))
    set('ListenPort', int(machine.get('nm_listen_port', 5556)))
    set('NMType', machine.get('nm_type', 'SSL'))

# Create managed servers
for server in managed_servers:
    sname = server.get('name')
    if not sname:
        continue
    cd('/')
    create(sname, 'Server')
    cd('/Servers/' + sname)
    if server.get('listen_address'):
        set('ListenAddress', server.get('listen_address'))
    if server.get('listen_port'):
        set('ListenPort', int(server.get('listen_port')))

    # Enable HTTP tunneling on managed server
    if tunneling_enabled:
        set('TunnelingEnabled', 'true')
    else:
        set('TunnelingEnabled', 'false')

    # Assign to cluster if defined
    if cluster_enabled:
        scluster = server.get('cluster') or cluster_name
        if scluster:
            assign('Server', sname, 'Cluster', scluster)

    # Assign to machine if defined
    smachine = server.get('machine')
    if smachine:
        assign('Server', sname, 'Machine', smachine)

# Configure unique Admin Console session cookie name to avoid login conflicts in same browser
cd('/')
admin_console = cmo.getAdminConsole()
admin_console.setCookieName('ADMINCONSOLESESSION_' + domain_name.upper())
print 'INFO: Configured Admin Console cookie name to ADMINCONSOLESESSION_' + domain_name.upper()
cd('/')

# Write the domain
print 'INFO: Writing domain to ' + domain_home
writeDomain(domain_home)
closeTemplate()

print 'INFO: Domain ' + domain_name + ' created successfully at ' + domain_home
exit()
