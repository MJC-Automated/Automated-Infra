# templates/start_weblogic.sh.j2
#!/bin/bash
# Start WebLogic Admin Server

unset DISPLAY
TIME=`/usr/bin/date +%b-%d-%Y-%H%M%S`

export JAVA_HOME="{{ java_home }}"
export PATH="$JAVA_HOME/bin:$PATH"

export USER_MEM_ARGS="{{ wlst_user_mem_args | default(weblogic_user_mem_args) }}"
export JAVA_OPTIONS="-Djava.net.preferIPv4Stack=true -Dcoherence.clusterport={{ wlst_coherence_port | default(7574) }} -Dcoherence.cluster={{ wlst_domain_name | default(domain_name) }}_Coherence -Dcoherence.localhost={{ wlst_coherence_localhost | default(ansible_host | default('127.0.0.1')) }} -Dcoherence.localport=0 -Dcoherence.localport.adjust=true -Dcoherence.wka={{ wlst_coherence_wka | default(wlst_coherence_localhost | default(ansible_host | default('127.0.0.1'))) }} $JAVA_OPTIONS"

# Ensure GC log target exists before JVM startup so rotation does not fail on missing paths.
GC_LOG_FILE="{{ wlst_gc_log_file | default(weblogic_gc_log_file | default('')) }}"
if [ -n "$GC_LOG_FILE" ]; then
  /usr/bin/mkdir -p "$(dirname "$GC_LOG_FILE")"
  /usr/bin/touch "$GC_LOG_FILE"
fi

echo "INFO: Starting {{ wlst_admin_server_name | default(admin_server_name) }} for {{ wlst_domain_name | default(domain_name) }}"

cd "{{ wlst_domain_home | default(domain_home) }}/bin" || { echo "ERROR: Cannot change to domain bin directory"; exit 1; }

exec ./startWebLogic.sh > "{{ wlst_admin_logs_dir | default(admin_logs_dir) }}/start_{{ wlst_admin_server_name | default(admin_server_name) }}_$TIME.log" 2>&1

echo "INFO: Start command issued."
