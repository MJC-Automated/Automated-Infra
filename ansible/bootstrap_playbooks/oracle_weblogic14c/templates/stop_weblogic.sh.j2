# templates/stop_weblogic.sh.j2
#!/bin/bash
# Stop WebLogic Admin Server

TIME=`/usr/bin/date +%b-%d-%Y-%H%M%S`

export JAVA_HOME="{{ java_home }}"
export PATH="$JAVA_HOME/bin:$PATH"

echo "INFO: Stopping {{ wlst_admin_server_name | default(admin_server_name) }} for {{ wlst_domain_name | default(domain_name) }}"

cd "{{ wlst_domain_home | default(domain_home) }}/bin" || { echo "ERROR: Cannot change to domain bin directory"; exit 1; }

./stopWebLogic.sh {{ wlst_admin_user | default(weblogic_admin_user) }} "{{ weblogic_password }}" > "{{ wlst_admin_logs_dir | default(admin_logs_dir) }}/stop_{{ wlst_admin_server_name | default(admin_server_name) }}_$TIME.log" 2>&1

echo "INFO: Stop command issued."
