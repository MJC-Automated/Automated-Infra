# Controller-side secrets for WebLogic 14c automation.
# Copy to .env, set strong values, and keep file mode 600.

WLS_ADMIN_PASSWORD=<set-strong-weblogic-admin-password>

# Required only when rcu_enabled=true
RCU_SCHEMA_PASSWORD=<set-strong-rcu-schema-password>
RCU_DB_PASSWORD=<set-strong-rcu-db-sys-password>
