services:
  prometheus:
    image: prom/prometheus:v2.54.1
    container_name: prometheus
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time={{ observability_prometheus_retention }}"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    ports:
      - "9090:9090"
    volumes:
      - "{{ observability_stack_dir }}/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro"
      - "/var/lib/prometheus:/prometheus"
    restart: unless-stopped

  loki:
    image: grafana/loki:3.2.1
    container_name: loki
    command: ["-config.file=/etc/loki/local-config.yml"]
    ports:
      - "3100:3100"
    volumes:
      - "{{ observability_stack_dir }}/loki/loki-config.yml:/etc/loki/local-config.yml:ro"
      - "/var/lib/loki:/loki"
    restart: unless-stopped

  tempo:
    image: grafana/tempo:2.6.1
    container_name: tempo
    command: ["-config.file=/etc/tempo.yaml"]
    ports:
      - "127.0.0.1:3200:3200"
    volumes:
      - "{{ observability_stack_dir }}/tempo/tempo.yml:/etc/tempo.yaml:ro"
      - "/var/lib/tempo:/var/tempo"
    restart: unless-stopped

  grafana:
    image: grafana/grafana:11.2.0
    container_name: grafana
    environment:
      GF_SECURITY_ADMIN_USER: "${OBS_GRAFANA_ADMIN_USER}"
      GF_SECURITY_ADMIN_PASSWORD: "${OBS_GRAFANA_ADMIN_PASSWORD}"
    ports:
      - "3000:3000"
    volumes:
      - "/var/lib/grafana:/var/lib/grafana"
      - "{{ observability_stack_dir }}/grafana/provisioning/datasources:/etc/grafana/provisioning/datasources:ro"
    restart: unless-stopped

  otel-collector:
    image: otel/opentelemetry-collector-contrib:0.108.0
    container_name: otel-collector
    command: ["--config=/etc/otelcol-contrib/config.yaml"]
    ports:
      - "4317:4317"
      - "4318:4318"
    volumes:
      - "{{ observability_stack_dir }}/otel/otel-collector-config.yml:/etc/otelcol-contrib/config.yaml:ro"
    restart: unless-stopped

  node-exporter:
    image: prom/node-exporter:v1.8.2
    container_name: node-exporter
    command:
      - "--path.rootfs=/host"
    network_mode: host
    pid: host
    volumes:
      - "/:/host:ro,rslave"
    restart: unless-stopped
