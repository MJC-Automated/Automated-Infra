# Copy to ansible/bootstrap_playbooks/gitlab/.env and chmod 600.

# GitLab Server configuration
GITLAB_EDITION=gitlab-ce
GITLAB_VERSION=19.1.2-ce.0
# Optional: install from a pre-downloaded .deb instead of the GitLab apt repo.
# GITLAB_PACKAGE_PATH=/resources/gitlab-ce_19.1.2-ce.0_amd64.deb
# Port and IP where GitLab will be accessible (no public DNS required)
GITLAB_EXTERNAL_URL=http://198.51.100.28
GITLAB_TIME_ZONE=Africa/Nairobi

# GitLab root/API bootstrap secrets.
# Leave unset to generate files under ansible/bootstrap_playbooks/gitlab/files/.
GITLAB_ROOT_PASSWORD=
GITLAB_API_TOKEN=

# Application defaults
GITLAB_SIGNUP_ENABLED=false
GITLAB_DEFAULT_PROJECT_VISIBILITY=private
GITLAB_DEFAULT_GROUP_VISIBILITY=private
GITLAB_DEFAULT_SNIPPET_VISIBILITY=private
GITLAB_DEFAULT_PROJECTS_LIMIT=100
GITLAB_SITE_TITLE=Homelab GitLab
GITLAB_SITE_DESCRIPTION=Local GitLab instance managed by Ansible.
GITLAB_HEADER_MESSAGE=Homelab GitLab - local network only
GITLAB_MESSAGE_FONT_COLOR=#ffffff
GITLAB_MESSAGE_BACKGROUND_COLOR=#1f2937
GITLAB_FOOTER_MESSAGE=
GITLAB_CONFIGURE_APPLICATION_SETTINGS=true
GITLAB_CONFIGURE_APPEARANCE=true
GITLAB_CONFIGURE_ROOT_PREFERENCES=true

# GitLab Runner configuration
# Runner tasks are skipped when no hosts are in gitlab_runner/gitlab_runners.
# With multiple runner hosts, omit GITLAB_RUNNER_NAME so each runner defaults
# to its inventory hostname, or set gitlab_runner_name in host_vars.
# GITLAB_RUNNER_NAME=public-pve1-gitlab-runner-01
GITLAB_RUNNER_EXECUTOR=docker
GITLAB_RUNNER_DOCKER_IMAGE=ubuntu:24.04
GITLAB_RUNNER_TAGS=docker,local,homelab
GITLAB_RUNNER_RUN_UNTAGGED=true
GITLAB_RUNNER_LOCKED=false
GITLAB_RUNNER_PAUSED=false
GITLAB_RUNNER_ACCESS_LEVEL=not_protected
GITLAB_RUNNER_MAXIMUM_TIMEOUT=7200
GITLAB_RUNNER_CONCURRENT=4
GITLAB_RUNNER_LIMIT=0
GITLAB_RUNNER_DOCKER_PRIVILEGED=false
GITLAB_RUNNER_DOCKER_PULL_POLICY=if-not-present
GITLAB_RUNNER_DOCKER_VOLUMES=/cache,/var/run/docker.sock:/var/run/docker.sock
GITLAB_RUNNER_DOCKER_ALLOWED_PULL_POLICIES=always,if-not-present
GITLAB_RUNNER_INSTALL_DOCKER=true
GITLAB_RUNNER_DOCKER_PACKAGE_SOURCE=ubuntu
# Optional local runner package:
# GITLAB_RUNNER_PACKAGE_PATH=/resources/gitlab-runner_19.1.1-1_amd64.deb
