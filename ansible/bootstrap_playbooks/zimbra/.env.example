# Optional overrides. Without this file, tracked non-secret settings are used
# and a random persistent password seed is generated under files/ with mode 0600.
# This file is parsed automatically by ansible/bootstrap_playbooks/zimbra/main.yml.

# Required: local artifact path on the Ansible controller
ZIMBRA_ARTIFACT_PATH=/resources/zcs-10.1.15_GA_4200001.RHEL9_64.20260110181427.tgz

# Optional staging + behavior controls
ZIMBRA_INSTALL_BASE_DIR=/zimbra/zimbra-installer
ZIMBRA_USE_MOUNTED_DATA_DIR=true
ZIMBRA_DATA_MOUNT_PATH=/zimbra
ZIMBRA_DATA_ROOT=/zimbra/opt-zimbra
ZIMBRA_INSTALL_TIMEOUT=7200
ZIMBRA_VERIFY_TIMEOUT=600
ZIMBRA_SKIP_SPACE_CHECK=true
ZIMBRA_PLATFORM_OVERRIDE=false
ZIMBRA_MANAGE_HOSTNAME=true
ZIMBRA_MANAGE_HOSTS_FILE=true
ZIMBRA_DISABLE_SELINUX=true
ZIMBRA_MANAGE_POSTFIX_CONFLICTS=true
ZIMBRA_INSTALL_ORACLE_EPEL=true
ZIMBRA_MANAGE_FIREWALL=true
ZIMBRA_FIREWALL_ALLOWED_PORTS=25/tcp,80/tcp,110/tcp,143/tcp,443/tcp,465/tcp,587/tcp,993/tcp,995/tcp,7071/tcp
ZIMBRA_DISABLE_IMAPD_WHEN_MAILBOX=false
ZIMBRA_IMAPD_AUTO_DISABLE_ON_FAILURE=true

# Random-style sample identity data
ZIMBRA_MAIL_DOMAIN=mail-9f8a1c7b.lab
ZIMBRA_SHORT_HOSTNAME=mx-c4d2aa
ZIMBRA_HOSTNAME=mx-c4d2aa.mail-9f8a1c7b.lab
ZIMBRA_ADMIN_EMAIL=admin@mail-9f8a1c7b.lab
ZIMBRA_AV_NOTIFY_EMAIL=notify-a1b2c3@mail-9f8a1c7b.lab
ZIMBRA_SMTP_SOURCE_EMAIL=smtp-src-a1b2c3@mail-9f8a1c7b.lab
ZIMBRA_SMTP_DEST_EMAIL=smtp-dst-a1b2c3@mail-9f8a1c7b.lab

# Secrets (set strong values)
ZIMBRA_ADMIN_PASSWORD=<set-strong-admin-password>
ZIMBRA_LDAP_ROOT_PASSWORD=<set-strong-ldap-root-password>
ZIMBRA_LDAP_ZIMBRA_PASSWORD=<set-strong-ldap-zimbra-password>
ZIMBRA_LDAP_POSTFIX_PASSWORD=<set-strong-ldap-postfix-password>
ZIMBRA_LDAP_REPLICATION_PASSWORD=<set-strong-ldap-replication-password>
ZIMBRA_LDAP_AMAVIS_PASSWORD=<set-strong-ldap-amavis-password>
ZIMBRA_LDAP_NGINX_PASSWORD=<set-strong-ldap-nginx-password>

# Service config
ZIMBRA_SERVICE_MODE=http
ZIMBRA_ALLOW_SELF_SIGNED=yes
ZIMBRA_START_SERVERS=yes
ZIMBRA_ENABLE_AV=yes
ZIMBRA_ENABLE_SA=yes
ZIMBRA_MTA_LMTP_HOST_LOOKUP=native

# Comma-separated lists
ZIMBRA_REQUIRED_PACKAGES=perl,rsyslog,wget,tar,sudo,net-tools,which,openssl,nmap-ncat,libidn2,p7zip-plugins
ZIMBRA_INSTALL_PACKAGES=zimbra-core,zimbra-ldap,zimbra-logger,zimbra-mta,zimbra-dnscache,zimbra-snmp,zimbra-store,zimbra-apache,zimbra-spell,zimbra-proxy
ZIMBRA_WEBAPPS=service,admin,zimlet

# Resolve missing component packages from Zimbra repositories
ZIMBRA_USE_ZIMBRA_PACKAGE_SERVER=yes
ZIMBRA_PACKAGE_SERVER=
