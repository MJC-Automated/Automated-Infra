# {{ ansible_managed }}
# Unified chrony configuration managed by Ansible

{% if time_sync_is_server | bool %}
# Upstream sources for this NTP server
{% for s in time_sync_public_servers | default([]) %}
server {{ s }} iburst
{% endfor %}

# Permit client subnet(s) to query this host
allow {{ time_sync_allowed_subnet }}

{% if time_sync_server_enable_local_fallback | bool %}
# Keep serving time even if upstream is unavailable
local stratum {{ time_sync_server_local_stratum }}
{% endif %}
{% else %}
# Client sources resolved from inventory and role vars
{% for s in time_sync_client_effective_sources | default([]) %}
server {{ s }} iburst
{% endfor %}
{% endif %}

# Driftfile location
driftfile /var/lib/chrony/drift

# Allow stepping the clock
{% if time_sync_force_makestep | bool %}
makestep 1.0 -1
{% else %}
makestep 1.0 3
{% endif %}

# RTC synchronization
rtcsync

# Authentication keys file
keyfile /etc/chrony.keys

# NTS keys and cookies storage
ntsdumpdir /var/lib/chrony

# Log directory
logdir /var/log/chrony

{% if ansible_facts.os_family == 'Debian' %}
# Debian-specific options
confdir /etc/chrony/conf.d
sourcedir /etc/chrony/sources.d
include /etc/chrony/conf.d/*.conf
{% elif ansible_facts.os_family == 'RedHat' %}
# RedHat-specific options
sourcedir /run/chrony-dhcp
leapsectz right/UTC
include /etc/chrony.d/*.conf
{% endif %}
