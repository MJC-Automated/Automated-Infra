# {{ ansible_managed }}
{% if time_sync_is_server %}
{% for s in time_sync_public_servers %}
pool {{ s }} iburst
{% endfor %}
allow {{ time_sync_allowed_subnet }}
local stratum 10
{% else %}
server {{ time_sync_server_host }} iburst
{% endif %}

sourcedir /run/chrony-dhcp
driftfile /var/lib/chrony/drift
makestep 1.0 3
rtcsync
keyfile /etc/chrony.keys
ntsdumpdir /var/lib/chrony
leapsectz right/UTC
logdir /var/log/chrony
