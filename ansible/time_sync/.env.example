# Copy this file to ansible/time_sync/.env and adjust values for your environment.

# Subnet allowed to query the fallback NTP server (control node)
TIME_SYNC_ALLOWED_SUBNET=203.0.113.0/24

# IP/FQDN that clients should use to reach the control-node NTP service
# Leave empty to auto-resolve from inventory facts.
TIME_SYNC_SERVER_ADVERTISE_IP=

# Optional comma-separated override for upstream public NTP servers on the fallback server
# TIME_SYNC_PUBLIC_SERVERS=0.pool.ntp.org,1.pool.ntp.org,2.pool.ntp.org,3.pool.ntp.org

# Optional comma-separated explicit NTP sources for clients
# TIME_SYNC_CLIENT_NTP_SERVERS=198.51.100.24

# Optional behavior flags
TIME_SYNC_CLIENT_USE_INTERNAL_SERVERS=true
TIME_SYNC_CLIENT_ADD_PUBLIC_FALLBACK=false
TIME_SYNC_SERVER_ENABLE_LOCAL_FALLBACK=true
TIME_SYNC_MANAGE_FIREWALL=true
TIME_SYNC_VERIFY_SYNC=true
