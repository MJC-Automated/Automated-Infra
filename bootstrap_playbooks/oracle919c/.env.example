# Oracle Environment Variables - keep controller-level defaults here and let group_vars/oracle_servers.yml express the desired databases/listeners per host.
ORACLE_USER=oracle
ORACLE_DB_ADMIN_PASSWORD=<set-strong-db-admin-password>
ORACLE_BASE_PARENT=/u01/app
ORACLE_DATA_DIR=/u02/oradata
ORACLE_FRA_DIR=/u02/fast_recovery_area

# Oracle Linux 9 requires Oracle Database 19c RU 19.19 or later.
# Place the zip files under /resources on the controller/Ansible source path.
ORACLE_RU_PATCH_ID=<set-ru-patch-id>
ORACLE_RU_PATCH_ZIP=<set-ru-patch-zip>
# Set this when the RU zip extracts a bundle and the DB RU lives in a nested directory.
# ORACLE_RU_PATCH_APPLY_DIR=/u01/stage/oracle19c/patches/<patch-bundle>/<db-ru-subdir>
# Optional latest OPatch zip. The playbook validates OPatch/version.txt inside
# the archive, so the filename can be misleading if the archive reports a
# supported 19c OPatch version. The uploaded OPatch bundle used for OL9 is
# version 12.2.0.1.42 even if the filename label looks older.
# ORACLE_OPATCH_ZIP=<set-opatch-zip>

# Additional CDB/PDB/listener definitions live under group_vars/oracle_servers.yml or host_vars/<inventory_hostname>.yml.
# Export ANSIBLE_TIMEOUT to override the default SSH/async timeout (see ansible.cfg default_timeout).
