# Copy to bootstrap_playbooks/keycloak/.env and chmod 600.

KEYCLOAK_VERSION=26.2.0
KEYCLOAK_HOSTNAME=keycloak.example.internal
KEYCLOAK_HTTP_PORT=8080
KEYCLOAK_HTTPS_PORT=8443
KEYCLOAK_HEALTH_PORT=9000
KEYCLOAK_PROXY_HEADERS=xforwarded
KEYCLOAK_HTTP_ENABLED=true
KEYCLOAK_MANAGE_FIREWALL=true
KEYCLOAK_MANAGE_DATABASE=true

KEYCLOAK_DB_HOST=127.0.0.1
KEYCLOAK_DB_PORT=5432
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=<set-strong-db-password>
# For remote DB provisioning when KEYCLOAK_DB_HOST points away from the Keycloak host.
KEYCLOAK_DB_ADMIN_USER=postgres
KEYCLOAK_DB_ADMIN_DATABASE=postgres
KEYCLOAK_DB_ADMIN_PASSWORD=

KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=<set-strong-admin-password>
