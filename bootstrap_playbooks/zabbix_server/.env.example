# Copy to bootstrap_playbooks/zabbix_server/.env and set mode 600.
# This file is parsed automatically by bootstrap_playbooks/zabbix_server/main.yml.

# Core
ZABBIX_VERSION=7.0

# DB settings
# internal: local PostgreSQL on the same host
# external: remote PostgreSQL endpoint
ZABBIX_DB_MODE=internal
ZABBIX_DB_HOST=127.0.0.1
ZABBIX_DB_PORT=5432
ZABBIX_DB_NAME=zabbix
ZABBIX_DB_USER=zabbix
ZABBIX_DB_PASSWORD=<set-strong-db-password>
# Keep empty to use PostgreSQL default search_path (public).
# Set only if you intentionally imported schema into a custom namespace.
ZABBIX_DB_SCHEMA=

# Frontend DB credential storage for "Configure DB connection":
# - plaintext: store DB user/password in zabbix.conf.php
# - hashicorp: read DB user/password from HashiCorp Vault
ZABBIX_DB_CREDENTIALS_STORE=plaintext

# HashiCorp Vault settings (required only when ZABBIX_DB_CREDENTIALS_STORE=hashicorp).
# Secret JSON must contain keys: username and password
# Example path (KV v2): secret/zabbix/db
# Zabbix builds URL as: <vault_url>/v1/<path with /data inserted after mount> when prefix is empty.
ZABBIX_DB_VAULT_URL=https://localhost:8200
ZABBIX_DB_VAULT_PREFIX=
ZABBIX_DB_VAULT_DB_PATH=
# Keep vault token out of git; set via local .env or injected secret.
# ZABBIX_DB_VAULT_TOKEN=
ZABBIX_DB_VAULT_CACHE=false

# DB bootstrap controls
# true  => create user/database if missing
# false => expect DB/user to pre-exist
ZABBIX_DB_MANAGE_USER_AND_DB=true

# true  => import server.sql.gz once (when dbversion table is absent)
# false => skip schema import
ZABBIX_DB_IMPORT_SCHEMA=true

# Needed only when:
# - ZABBIX_DB_MODE=external
# - ZABBIX_DB_MANAGE_USER_AND_DB=true
# ZABBIX_DB_ADMIN_USER=postgres
# ZABBIX_DB_ADMIN_PASSWORD=<set-db-admin-password>

# Optional behavior flags
ZABBIX_MANAGE_AGENT2_PLUGINS=false
ZABBIX_MANAGE_FIREWALL=false
ZABBIX_ORACLE_EXCLUDE_EPEL_ZABBIX=true
ZABBIX_SERVICE_ENABLE=true
ZABBIX_SERVICE_START=true
ZABBIX_PHP_TIMEZONE=UTC
# Optional UI display name in the top-right corner.
ZABBIX_FRONTEND_SERVER_NAME=

# Backup policy
# Daily backup with rotation:
# - keep newest raw dump
# - keep last 2 archived dumps
# - keep max 3 backups total
ZABBIX_BACKUP_ENABLED=true
ZABBIX_BACKUP_MOUNT_POINT=/var/backups
ZABBIX_BACKUP_DIR=/var/backups/zabbix-data
ZABBIX_BACKUP_KEEP_ARCHIVED=2
ZABBIX_BACKUP_KEEP_MAX=3
ZABBIX_BACKUP_SCHEDULE_HOUR=2
ZABBIX_BACKUP_SCHEDULE_MINUTE=15
ZABBIX_BACKUP_REQUIRE_MOUNT=false

# Optional advanced overrides
# ZABBIX_BACKUP_SCRIPT_PATH=/usr/local/bin/zabbix-db-backup.sh
# ZABBIX_BACKUP_LOG_PATH=/var/log/zabbix-db-backup.log
