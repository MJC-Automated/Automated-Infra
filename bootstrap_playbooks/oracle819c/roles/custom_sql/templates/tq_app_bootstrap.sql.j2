FLASHBACK ON;

CREATE TABLESPACE MEDDATA DATAFILE 
  '/u02/oradata/{{ oracle_app_database_name }}/med01.dbf' SIZE 100M AUTOEXTEND ON NEXT 1M MAXSIZE UNLIMITED
LOGGING
ONLINE
EXTENT MANAGEMENT LOCAL AUTOALLOCATE
