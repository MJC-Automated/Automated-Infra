-- tq_app_bootstrap.sql.j2
-- This script runs inside a target PDB selected by Ansible.
-- Variables available in this template:
--   oracle_app_database_name (example: FMSDEV)
--   oracle_app_pdb_name      (example: MUTUAL, GLICO)
--   oracle_app_cdb_sid       (example: CDB1)
--
-- Keep your full CREATE USER / GRANT / QUOTA statements in this file.
-- Tip:
--   Replace hardcoded datafile paths like /u02/oradata/{{ oracle_app_database_name }}/... with:
--   /u02/oradata/{{ oracle_app_database_name }}/...

prompt Applying custom SQL bootstrap for {{ oracle_app_database_name }} in {{ oracle_app_pdb_name }} (CDB {{ oracle_app_cdb_sid }})

CREATE TABLESPACE FMSDATA DATAFILE 
  '/u02/oradata/{{ oracle_app_database_name }}/fms01.dbf' SIZE 5G AUTOEXTEND ON NEXT 1M MAXSIZE UNLIMITED
LOGGING
ONLINE
EXTENT MANAGEMENT LOCAL AUTOALLOCATE
BLOCKSIZE 8K
SEGMENT SPACE MANAGEMENT MANUAL
FLASHBACK ON;
CREATE TABLESPACE CRMDATA DATAFILE 
  '/u02/oradata/{{ oracle_app_database_name }}/crm01.dbf' SIZE 400M AUTOEXTEND ON NEXT 1M MAXSIZE UNLIMITED
LOGGING
ONLINE
EXTENT MANAGEMENT LOCAL AUTOALLOCATE
BLOCKSIZE 8K
SEGMENT SPACE MANAGEMENT MANUAL
FLASHBACK ON;

CREATE TABLESPACE GISDATA DATAFILE 
  '/u02/oradata/{{ oracle_app_database_name }}/gis01.dbf' SIZE 2G AUTOEXTEND ON NEXT 1M MAXSIZE UNLIMITED
LOGGING
ONLINE
EXTENT MANAGEMENT LOCAL AUTOALLOCATE
BLOCKSIZE 8K
SEGMENT SPACE MANAGEMENT MANUAL
FLASHBACK ON;
 CREATE TABLESPACE LMSDATA DATAFILE 
  '/u02/oradata/{{ oracle_app_database_name }}/lms01.dbf' SIZE 3G AUTOEXTEND ON NEXT 1M MAXSIZE UNLIMITED
LOGGING
ONLINE
EXTENT MANAGEMENT LOCAL AUTOALLOCATE
