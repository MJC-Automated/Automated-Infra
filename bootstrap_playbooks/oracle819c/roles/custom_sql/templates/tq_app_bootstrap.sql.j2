-- 2 Tablespace Quotas for TQ_LMS 
ALTER USER TQ_LMS QUOTA UNLIMITED ON LMSDATA;
DECLARE
  l_users_ts_exists NUMBER;
BEGIN
  SELECT COUNT(*) INTO l_users_ts_exists FROM dba_tablespaces WHERE tablespace_name = 'USERS';
  IF l_users_ts_exists > 0 THEN
    EXECUTE IMMEDIATE 'ALTER USER TQ_LMS QUOTA UNLIMITED ON USERS';
  END IF;
END;
/

