# templates/stop_weblogic.sh.j2
#!/bin/bash
# Stop WebLogic Admin Server

TIME=`/usr/bin/date +%b-%d-%Y-%H%M%S`

export JAVA_HOME="{{ java_home }}"
export PATH="$JAVA_HOME/bin:$PATH"

echo "INFO: Stopping {{ admin_server_name }} for {{ domain_name }}"

cd "{{ domain_home }}/bin" || { echo "ERROR: Cannot change to domain bin directory"; exit 1; }

/usr/bin/nohup ./stopWebLogic.sh {{ weblogic_admin_user }} "{{ weblogic_password }}" > "{{ admin_logs_dir }}/stop_{{ admin_server_name }}_$TIME.log" 2>&1 &

echo "INFO: Stop command issued."
