# templates/stop_managed.sh.j2
#!/bin/bash
# Stop a WebLogic Managed Server

TIME=`/usr/bin/date +%b-%d-%Y-%H%M%S`

export JAVA_HOME="{{ java_home }}"
export PATH="$JAVA_HOME/bin:$PATH"

echo "INFO: Stopping managed server {{ managed_server_name }} for {{ domain_name }}"

echo "INFO: Admin URL: {{ admin_url }}"

cd "{{ domain_home }}/bin" || { echo "ERROR: Cannot change to domain bin directory"; exit 1; }

/usr/bin/nohup ./stopManagedWebLogic.sh "{{ managed_server_name }}" "{{ weblogic_admin_user }}" "{{ weblogic_password }}" "{{ admin_url }}" > "{{ managed_server_logs_dir }}/stop_{{ managed_server_name }}_$TIME.log" 2>&1 &

echo "INFO: Stop command issued."
