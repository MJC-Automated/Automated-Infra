# templates/start_weblogic.sh.j2
#!/bin/bash
# Script to start the WebLogic Admin Server for {{ domain_name }}

unset DISPLAY # Prevents GUI errors in nohup

# Use full path for 'date' command to ensure it's found
# Changed timestamp format to include Year, Hour, Minute, and Second for uniqueness and readability.
TIME=`/usr/bin/date +%b-%d-%Y-%H%M%S`

# Ensure JAVA_HOME is set for the script context
export JAVA_HOME="{{ java_home }}"
export PATH="$JAVA_HOME/bin:$PATH"

export USER_MEM_ARGS="{{ weblogic_user_mem_args_effective | default(weblogic_user_mem_args) }}"

# Ensure GC log target exists before JVM startup so rotation does not fail on missing paths.
GC_LOG_FILE="{{ weblogic_gc_log_file | default('') }}"
if [ -n "$GC_LOG_FILE" ]; then
  /usr/bin/mkdir -p "$(dirname "$GC_LOG_FILE")"
  /usr/bin/touch "$GC_LOG_FILE"
fi

echo "INFO: Starting WebLogic Admin Server for {{ domain_name }} on port {{ admin_port }}..."
echo "INFO: Logs will be redirected to {{ domain_logs_dir }}/startWeblogic_{{ domain_name | upper }}_$TIME.log"

# Navigate to domain bin directory and start the server
cd "{{ domain_home }}/bin" || { echo "ERROR: Could not change to domain bin directory."; exit 1; }

# Start the WebLogic server in the background, redirecting output to a log file
# Removed the trailing '&' as systemd manages the process, but nohup still detaches.
# The previous issue was 'date' command not found.
/usr/bin/nohup ./startWebLogic.sh > "{{ domain_logs_dir }}/startWeblogic_{{ domain_name | upper }}_$TIME.log" 2>&1 &

echo "INFO: WebLogic Admin Server start command issued."
